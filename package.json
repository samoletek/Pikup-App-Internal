{
  "name": "uber-clone",
  "license": "0BSD",
  "version": "1.0.35",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --cache",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest --runInBand",
    "check:smoke": "npm run lint && npx tsc --noEmit && npm run test -- --watch=false",
    "check:ai-entrypoint": "bash scripts/check_ai_entrypoint.sh",
    "boundaries:check": "bash scripts/check_supabase_boundaries.sh",
    "size:check": "bash scripts/check_module_size.sh",
    "errors:check": "bash scripts/check_service_error_normalization.sh",
    "dispatch:smoke": "node scripts/dispatch_smoke.js",
    "hooks:install": "git config core.hooksPath .githooks",
    "postinstall": "patch-package",
    "eas-build-on-error": "bash -lc 'set -e; echo === MANIFEST FAILURE REPORTS ===; find android -path \"*/outputs/logs/*manifest-merger*failure-report*.txt\" -print -exec bash -lc \"echo --- {}; echo; sed -n \\\"1,400p\\\" {}\" \\; || true; echo === MANIFEST REPORTS (ALL) ===; find android -path \"*/outputs/logs/*manifest-merger*debug*.txt\" -o -path \"*/outputs/logs/*manifest-merger*release*.txt\" -print -exec bash -lc \"echo --- {}; echo; sed -n \\\"1,200p\\\" {}\" \\; || true; echo === MERGED MANIFESTS (APP) ===; find android/app/build/intermediates/merged_manifests -name AndroidManifest.xml -print -exec bash -lc \"echo --- {}; echo; sed -n \\\"1,200p\\\" {}\" \\; || true'"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.5.1",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/native": "^7.1.13",
    "@react-navigation/native-stack": "^7.3.18",
    "@rnmapbox/maps": "10.2.10",
    "@stripe/stripe-identity-react-native": "0.4.1",
    "@stripe/stripe-react-native": "0.57.3",
    "@supabase/supabase-js": "^2.93.2",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.25",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/config-plugins": "^55.0.6",
    "@react-native-community/cli": "^20.0.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "babel-jest": "^30.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@stripe/stripe-identity-react-native"
        ]
      }
    }
  }
}
